# ============================================================
# Polymarket Bot - Variables de entorno
# Copia este archivo como .env y completa tus datos
# ============================================================

# --- Claves de Polymarket CLOB API ---
# Obtén tu API key en: https://polymarket.com (Settings > API)
POLY_API_KEY=tu_api_key_aqui
POLY_API_SECRET=tu_api_secret_aqui
POLY_API_PASSPHRASE=tu_passphrase_aqui

# --- Clave privada de tu wallet (sin 0x al inicio) ---
# Esta clave firma las transacciones on-chain
PRIVATE_KEY=tu_clave_privada_aqui

# --- Red (usa "polygon" para mainnet, "mumbai" para testnet) ---
NETWORK=polygon

# --- Configuración de riesgo ---
# Máximo USDC a invertir por operación
MAX_ORDER_SIZE_USDC=50

# Máximo USDC total en posiciones abiertas simultáneas
MAX_TOTAL_EXPOSURE_USDC=200

# Stop-loss: vender si la posición pierde más de este %
STOP_LOSS_PCT=20

# Take-profit: vender si la posición gana más de este %
TAKE_PROFIT_PCT=30

# --- Intervalo del bot en segundos ---
LOOP_INTERVAL_SECONDS=60

# --- Paper Trading ---
# Pon PAPER_TRADING=true para simular sin dinero real.
# Las credenciales de API NO son necesarias en paper mode.
PAPER_TRADING=false
PAPER_TRADING_BALANCE=1000
